# Copy to `.env` and fill in real values. Never commit `.env`.

# Skip Meta and use `data/mock_ads.json` (+ `mock_ads_rescrape.json` on re-scrape)
# USE_MOCK_META_ADS=true

# Meta Ad Library API — https://developers.facebook.com/tools/explorer/
# Permission: ads_read. Ad Library access: https://www.facebook.com/ID
META_ACCESS_TOKEN=your_meta_access_token_here

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional (defaults: gemini-2.5-flash for analyst and generator)
# GEMINI_MODEL_ANALYST=gemini-3-flash-preview
# GEMINI_MODEL_GENERATOR=gemini-3-flash-preview
